{
  "command": "execute",
  "overloads": [
    {
      "comment": "execute align <axes>",
      "pattern": [
        { "type": "word", "options": ["align"], "required": true },
        { "type": "word", "options": ["*"], "required": true }
      ]
    },
    {
      "comment": "execute as <target>",
      "pattern": [
        { "type": "word", "options": ["as"], "required": true },
        { "type": "target", "required": true }
      ]
    },
    {
      "comment": "execute at <target>",
      "pattern": [
        { "type": "word", "options": ["at"], "required": true },
        { "type": "target", "required": true }
      ]
    },
    {
      "comment": "execute facing <position: x y z>",
      "pattern": [
        { "type": "word", "options": ["facing"], "required": true },
        { "type": "int" }, { "type": "int" }, { "type": "int" }
      ]
    },
    {
      "comment": "execute facing entity <target> [eyes|feet]",
      "pattern": [
        { "type": "word", "options": ["facing"], "required": true },
        { "type": "word", "options": ["entity"], "required": true },
        { "type": "target", "required": true },
        { "type": "word", "options": ["eyes", "feet"], "required": false }
      ]
    },
    {
      "comment": "execute in <dimension>",
      "pattern": [
        { "type": "word", "options": ["in"], "required": true },
        { "type": "word", "options": ["*"], "required": true }
      ]
    },
    {
      "comment": "execute positioned <position: x y z>",
      "pattern": [
        { "type": "word", "options": ["positioned"], "required": true },
        { "type": "int" }, { "type": "int" }, { "type": "int" }
      ]
    },
    {
      "comment": "execute positioned as <target>",
      "pattern": [
        { "type": "word", "options": ["positioned"], "required": true },
        { "type": "word", "options": ["as"], "required": true },
        { "type": "target", "required": true }
      ]
    },
    {
      "comment": "execute rotated <yaw> <pitch>",
      "pattern": [
        { "type": "word", "options": ["rotated"], "required": true },
        { "type": "int" }, { "type": "int" }
      ]
    },
    {
      "comment": "execute rotated as <target>",
      "pattern": [
        { "type": "word", "options": ["rotated"], "required": true },
        { "type": "word", "options": ["as"], "required": true },
        { "type": "target", "required": true }
      ]
    },
    {
      "comment": "execute if/unless block <position: x y z> <block> [states]",
      "pattern": [
        { "type": "word", "options": ["if", "unless"], "required": true },
        { "type": "word", "options": ["block"], "required": true },
        { "type": "int" }, { "type": "int" }, { "type": "int" },
        { "type": "item_id", "required": true },
        { "type": "word", "options": ["*"], "required": false }
      ]
    },
    {
      "comment": "execute if/unless blocks <begin: x y z> <end: x y z> <destination: x y z> (all|masked)",
      "pattern": [
        { "type": "word", "options": ["if", "unless"], "required": true },
        { "type": "word", "options": ["blocks"], "required": true },
        { "type": "int" }, { "type": "int" }, { "type": "int" },
        { "type": "int" }, { "type": "int" }, { "type": "int" },
        { "type": "int" }, { "type": "int" }, { "type": "int" },
        { "type": "word", "options": ["all", "masked"], "required": true }
      ]
    },
    {
      "comment": "execute if/unless entity <target>",
      "pattern": [
        { "type": "word", "options": ["if", "unless"], "required": true },
        { "type": "word", "options": ["entity"], "required": true },
        { "type": "target", "required": true }
      ]
    },
    {
      "comment": "execute if/unless score <target> <objective> <operator> <source> <objective>",
      "pattern": [
        { "type": "word", "options": ["if", "unless"], "required": true },
        { "type": "word", "options": ["score"], "required": true },
        { "type": "target", "required": true },
        { "type": "word", "options": ["*"], "required": true },
        { "type": "word", "options": ["<", "<=", "=", ">=", ">"], "required": true },
        { "type": "target", "required": true },
        { "type": "word", "options": ["*"], "required": true }
      ]
    },
    {
      "comment": "execute if/unless score <target> <objective> matches <range>",
      "pattern": [
        { "type": "word", "options": ["if", "unless"], "required": true },
        { "type": "word", "options": ["score"], "required": true },
        { "type": "target", "required": true },
        { "type": "word", "options": ["*"], "required": true },
        { "type": "word", "options": ["matches"], "required": true },
        { "type": "word", "options": ["*"], "required": true }
      ]
    }
  ]
}
